# ────────────────────────────────────────────────────────────
# Astro Orbit Backend — Environment Configuration
# ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# --- Application ---
APP_NAME=astro-orbit-backend
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_HOST=0.0.0.0
APP_SECRET_KEY=change-me-to-a-random-64-byte-hex-string
APP_BASE_URL=http://localhost:8080

# --- Database ---
DATABASE_URL=postgres://astro_orbit:astro_orbit@localhost:5432/astro_orbit
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=4
DATABASE_MAX_LIFETIME_MINUTES=30
DATABASE_IDLE_TIMEOUT_SECONDS=600
DATABASE_CONNECT_TIMEOUT_SECONDS=10

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10
REDIS_DEFAULT_TTL_SECONDS=300

# --- Authentication ---
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
JWT_ISSUER=astro-orbit-backend
JWT_AUDIENCE=astro-orbit-api

# --- Stellar ---
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_RPC_TIMEOUT_SECONDS=30

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=astro-orbit-backend
METRICS_PORT=9090

# --- Authentication ---
AUTH_CHALLENGE_TTL_SECONDS=300

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10
RATE_LIMIT_BURST_SIZE=20

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# --- Security ---
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
